
local M = {}

function M.RefreshWorld()
	local pid = game.PlaceId
	M.World1 = pid == 2753915549 or pid == 85211729168715
	M.World2 = pid == 4442272183 or pid == 79091703265657
	M.World3 = pid == 7449423635 or pid == 100117331123089
	if M.World1 or M.World2 or M.World3 then return end
	local map = workspace:FindFirstChild("Map")
	if map then
		if map:FindFirstChild("TikiOutpost") or map:FindFirstChild("SubmergedIsland")
			or map:FindFirstChild("SeaOfTreats") or map:FindFirstChild("CastleOnTheSea")
			or map:FindFirstChild("MysticalTree") or map:FindFirstChild("HydraIsland") then
			M.World3 = true
			return
		end
		if map:FindFirstChild("Dressrosa") or map:FindFirstChild("Mansion") then
			M.World2 = true
			return
		end
	end
	local wo = workspace:FindFirstChild("_WorldOrigin") or workspace:FindFirstChild("_WorldOrigins")
	if wo and wo:FindFirstChild("Locations") then
		local loc = wo.Locations
		if loc:FindFirstChild("Tiki Outpost") or loc:FindFirstChild("Submerged Island")
			or loc:FindFirstChild("Temple of Time") or loc:FindFirstChild("Castle on the Sea") then
			M.World3 = true
		elseif loc:FindFirstChild("Green Zone") or loc:FindFirstChild("Mansion") then
			M.World2 = true
		end
	end
end

M.RefreshWorld()

