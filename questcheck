function M.GetQuestInfo(plr, useEntrance)
	M.QuestCheck(plr, useEntrance)
	return {
		Mon = M.Mon,
		Qdata = M.Qdata,
		Qname = M.Qname,
		PosM = M.PosM,
		NameMon = M.NameMon,
		PosQ = M.PosQ,
	}
end

function M.QuestNeta(plr, useEntrance)
